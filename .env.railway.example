ENGINE_MODE=COPILOT
POLL_MINUTES=5
ALERT_SIGNAL_QUALITIES=A1,A2
ALERT_MIN_CONFIDENCE=75
ALERT_COOLDOWN_MINUTES=180
TOTAL_CAPITAL=10000
MAX_POSITION_SIZE=1500
MAX_DAILY_DRAWDOWN=0.05
MAX_LEVERAGE=3
REQUESTED_LEVERAGE=1
FUNDING_THRESHOLD=0.0005
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_FROM_EMAIL=your_email@gmail.com
ALERT_TO_EMAIL=destination@gmail.com
SMTP_USE_TLS=true
