TELEGRAM_MIN_OPPORTUNITY_SCORE=45
TELEGRAM_MAX_ALERTS=3
ALERT_COOLDOWN_MINUTES=20
TELEGRAM_SEND_ON_EVERY_CYCLE=false

ENGINE_MODE=COPILOT
ENGINE_PRESET=DEFAULT
ENGINE_INTERVAL=1h
MONITOR_INTERVALS=15m,1h,4h
POLL_MINUTES=5
ENGINE_LIMIT=1000

NEWS_COLLECTION_ENABLED=true
NEWS_POLL_MINUTES=30
NEWS_LOOKBACK_HOURS=36
NEWS_MAX_ITEMS_PER_FEED=25
NEWS_INCLUDE_FEAR_GREED=true

BTC_BIAS_DATA_COLLECTION_ENABLED=true
BTC_BIAS_DATA_POLL_MINUTES=180
BTC_ETF_REMOTE_ENABLED=true
BTC_ETF_FLOWS_PATH=btc_etf_flows.csv
BTC_MVRV_PATH=btc_mvrv.csv
BTC_SOPR_PATH=btc_sopr.csv

# Optional if you have Glassnode.
# GLASSNODE_API_KEY=
# GLASSNODE_MVRV_PATH=/v1/metrics/market/mvrv
# GLASSNODE_SOPR_PATH=/v1/metrics/indicators/sopr_adjusted

ALERT_MIN_CONFIDENCE=75
ALERT_SIGNAL_QUALITIES=A1,A2
DOWNSIDE_ALERT_THRESHOLD_PCT=-2.5
DOWNSIDE_ALERT_3BAR_THRESHOLD_PCT=-4.0
